# ───────────────────────────────────────────────
# KANGALA SOVEREIGN — Environment (example)
# 
# Copy this file to `.env.local` and fill values.
# NEVER commit `.env.local` to git.
# ───────────────────────────────────────────────

# The gate password. DO NOT prefix with NEXT_PUBLIC_ — it must stay server-side.
GATE_PASSWORD=KANGALA2026

# Secret used to sign the auth cookie. Generate a random 32+ char string for production.
# e.g. `openssl rand -hex 32`
AUTH_SECRET=change-this-to-a-random-32+-character-string-in-production
